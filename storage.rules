rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isCraigEmail(email) {
      return email is string
        && email.matches("(?i)^peng871111@gmail\\.com$");
    }

    function isLeonEmail(email) {
      return email is string
        && email.matches("(?i)^dengue0111@gmail\\.com$");
    }

    function isAdmin() {
      return signedIn()
        && (
          userDoc().data.role == "admin"
          || userDoc().data.role == "super_admin"
          || isCraigEmail(request.auth.token.email)
          || isLeonEmail(request.auth.token.email)
        );
    }

    match /vehicle-images/{ownerUid}/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn() && (request.auth.uid == ownerUid || isAdmin());
    }

    match /dealer-proofs/{ownerUid}/{allPaths=**} {
      allow read, write: if signedIn() && (request.auth.uid == ownerUid || isAdmin());
    }

    match /warehouse-intakes/{intakeId}/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /vehicle-reports/{vehicleId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
