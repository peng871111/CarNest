rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return signedIn() && userDoc().data.role == "super_admin";
    }

    function isAdmin() {
      return signedIn()
        && (
          userDoc().data.role == "admin"
          || userDoc().data.role == "super_admin"
        );
    }

    function isSeller() {
      return signedIn() && userDoc().data.role == "seller";
    }

    function isApprovedDealer() {
      return signedIn()
        && userDoc().data.role == "dealer"
        && userDoc().data.dealerStatus == "approved";
    }

    function isSellerWorkspaceUser() {
      return signedIn()
        && (
          userDoc().data.role == "seller"
          || userDoc().data.role == "buyer"
          || userDoc().data.role == "dealer"
        );
    }

    function isCraigEmail(email) {
      return email == "peng871111@gmail.com";
    }

    function isLeonEmail(email) {
      return email == "dengue0111@gmail.com";
    }

    function isAllowedProfileRole(role, email) {
      return role == "buyer"
        || role == "seller"
        || role == "dealer"
        || (role == "admin" && isLeonEmail(email))
        || (role == "super_admin" && isCraigEmail(email));
    }

    function isValidOfferStatus(status) {
      return status == "pending"
        || status == "countered"
        || status == "accepted"
        || status == "declined"
        || status == "accepted_pending_buyer_confirmation"
        || status == "buyer_confirmed"
        || status == "buyer_declined"
        || status == "rejected";
    }

    function isValidOfferContactVisibilityState(value) {
      return value == "hidden"
        || value == "shared_after_accept"
        || value == "shared_after_counter_accept";
    }

    function isValidQuoteStatus(status) {
      return status == "NEW"
        || status == "CONTACTED"
        || status == "QUOTED"
        || status == "CLOSED";
    }

    function isValidInspectionRequestStatus(status) {
      return status == "NEW"
        || status == "CONTACTED"
        || status == "BOOKED"
        || status == "CLOSED";
    }

    function isValidContactMessageStatus(status) {
      return status == "NEW"
        || status == "CONTACTED"
        || status == "CLOSED";
    }

    function isValidPricingRequestStatus(status) {
      return status == "NEW"
        || status == "REPLIED"
        || status == "CLOSED";
    }

    function isValidPricingLeadRating(value) {
      return value == "HOT"
        || value == "WARM"
        || value == "COLD";
    }

    function isValidPricingNextAction(value) {
      return value == "Recommend warehouse"
        || value == "Follow up later"
        || value == "Not suitable";
    }

    function isValidVehicleViewRole(role) {
      return role == "guest"
        || role == "buyer"
        || role == "seller"
        || role == "admin"
        || role == "super_admin";
    }

    function isValidDeviceType(deviceType) {
      return deviceType == "mobile"
        || deviceType == "tablet"
        || deviceType == "desktop";
    }

    function isValidVehicleStatus(status) {
      return status == "pending"
        || status == "approved"
        || status == "rejected";
    }

    function isValidSellerVehicleStatus(status) {
      return status == "ACTIVE"
        || status == "UNDER_OFFER"
        || status == "PAUSED"
        || status == "WITHDRAWN"
        || status == "SOLD";
    }

    function vehicleStatusFieldsOnlyChanged() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "sellerStatus",
        "underOfferBuyerUid",
        "soldAt",
        "updatedAt"
      ]);
    }

    function submittedByMatchesUser() {
      return !("submittedByUid" in request.resource.data)
        || (signedIn() && request.resource.data.submittedByUid == request.auth.uid);
    }

    function vehicleOwnerUid(vehicleId) {
      return get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.ownerUid;
    }

    function offerFieldsUnchanged() {
      return request.resource.data.buyerUid == resource.data.buyerUid
        && request.resource.data.listingOwnerUid == resource.data.listingOwnerUid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.vehicleId == resource.data.vehicleId
        && request.resource.data.vehicleTitle == resource.data.vehicleTitle
        && request.resource.data.vehiclePrice == resource.data.vehiclePrice
        && request.resource.data.buyerName == resource.data.buyerName
        && request.resource.data.buyerEmail == resource.data.buyerEmail
        && request.resource.data.buyerPhone == resource.data.buyerPhone
        && request.resource.data.message == resource.data.message
        && request.resource.data.sellerOwnerUid == resource.data.sellerOwnerUid
        && request.resource.data.submittedByUid == resource.data.submittedByUid
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function offerAmountsAreValid() {
      return request.resource.data.amount is number
        && request.resource.data.offerAmount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount == request.resource.data.offerAmount;
    }

    function offerAmountsUnchanged() {
      return request.resource.data.amount == resource.data.amount
        && request.resource.data.offerAmount == resource.data.offerAmount;
    }

    function offerContactUnlockFieldsValid() {
      return request.resource.data.contactUnlocked is bool
        && (request.resource.data.contactUnlockedAt == null || request.resource.data.contactUnlockedAt is timestamp)
        && (
          request.resource.data.contactVisibilityState == null
          || isValidOfferContactVisibilityState(request.resource.data.contactVisibilityState)
        )
        && (
          request.resource.data.contactUnlockedBy == null
          || request.resource.data.contactUnlockedBy == "buyer_confirm"
          || request.resource.data.contactUnlockedBy == "seller_manual"
          || request.resource.data.contactUnlockedBy == "seller_accept"
          || request.resource.data.contactUnlockedBy == "buyer_counter_accept"
        );
    }

    function offerContactUnlockFieldsUnchanged() {
      return request.resource.data.contactUnlocked == resource.data.contactUnlocked
        && request.resource.data.contactUnlockedAt == resource.data.contactUnlockedAt
        && request.resource.data.contactUnlockedBy == resource.data.contactUnlockedBy
        && request.resource.data.contactVisibilityState == resource.data.contactVisibilityState;
    }

    function offerActivityNotificationOffer(offerId) {
      return get(/databases/$(database)/documents/offers/$(offerId));
    }

    function quoteFieldsUnchanged() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.sellerUid == resource.data.sellerUid
        && request.resource.data.sellerName == resource.data.sellerName
        && request.resource.data.sellerEmail == resource.data.sellerEmail
        && request.resource.data.vehicleId == resource.data.vehicleId
        && request.resource.data.vehicleYear == resource.data.vehicleYear
        && request.resource.data.vehicleMake == resource.data.vehicleMake
        && request.resource.data.vehicleModel == resource.data.vehicleModel
        && request.resource.data.quoteType == resource.data.quoteType
        && request.resource.data.source == resource.data.source
        && request.resource.data.notes == resource.data.notes
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function inspectionRequestFieldsUnchanged() {
      return request.resource.data.vehicleId == resource.data.vehicleId
        && request.resource.data.vehicleTitle == resource.data.vehicleTitle
        && request.resource.data.buyerName == resource.data.buyerName
        && request.resource.data.buyerEmail == resource.data.buyerEmail
        && request.resource.data.buyerPhone == resource.data.buyerPhone
        && request.resource.data.preferredTime == resource.data.preferredTime
        && request.resource.data.message == resource.data.message
        && request.resource.data.listingType == resource.data.listingType
        && request.resource.data.sellerOwnerUid == resource.data.sellerOwnerUid
        && request.resource.data.submittedByUid == resource.data.submittedByUid
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function pricingRequestBaseFieldsUnchanged() {
      return request.resource.data.userId == resource.data.userId
        && request.resource.data.vehicleId == resource.data.vehicleId
        && request.resource.data.currentPrice == resource.data.currentPrice
        && request.resource.data.timeline == resource.data.timeline
        && request.resource.data.message == resource.data.message
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          "uid",
          "email",
          "role",
          "createdAt",
          "displayName",
          "name",
          "phone",
          "accountReference",
          "adminPermissions",
          "complianceStatus",
          "complianceFlaggedAt",
          "dealerStatus",
          "dealerVerified",
          "dealerApplicationId",
          "listingRestricted",
          "failedLoginAttempts",
          "mustResetPassword"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && isAllowedProfileRole(request.resource.data.role, request.resource.data.email)
        && request.resource.data.createdAt is timestamp
        && (
          !("complianceStatus" in request.resource.data)
          || request.resource.data.complianceStatus == "clear"
        )
        && (
          !("complianceFlaggedAt" in request.resource.data)
          || request.resource.data.complianceFlaggedAt is timestamp
        )
        && (
          !("dealerStatus" in request.resource.data)
          || request.resource.data.dealerStatus == "none"
          || request.resource.data.dealerStatus == "submitted_unverified"
          || request.resource.data.dealerStatus == "pending"
          || request.resource.data.dealerStatus == "info_requested"
          || request.resource.data.dealerStatus == "approved"
          || request.resource.data.dealerStatus == "rejected"
        )
        && (
          !("dealerVerified" in request.resource.data)
          || request.resource.data.dealerVerified is bool
        )
        && (
          !("dealerApplicationId" in request.resource.data)
          || request.resource.data.dealerApplicationId is string
        )
        && (
          !("listingRestricted" in request.resource.data)
          || request.resource.data.listingRestricted is bool
        )
        && request.resource.data.failedLoginAttempts is int
        && request.resource.data.mustResetPassword is bool;
      allow update: if isSuperAdmin()
        || (
          signedIn()
          && request.auth.uid == userId
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.adminPermissions == resource.data.adminPermissions
          && (
            !("complianceStatus" in request.resource.data)
            || request.resource.data.complianceStatus == "clear"
            || request.resource.data.complianceStatus == "possible_unlicensed_trader"
          )
          && (
            !("complianceFlaggedAt" in request.resource.data)
            || request.resource.data.complianceFlaggedAt is timestamp
          )
          && (
            !("dealerStatus" in request.resource.data)
            || request.resource.data.dealerStatus == "none"
            || request.resource.data.dealerStatus == "submitted_unverified"
            || request.resource.data.dealerStatus == "pending"
            || request.resource.data.dealerStatus == "info_requested"
            || request.resource.data.dealerStatus == "approved"
            || request.resource.data.dealerStatus == "rejected"
          )
          && (
            !("dealerVerified" in request.resource.data)
            || request.resource.data.dealerVerified is bool
          )
          && (
            !("dealerApplicationId" in request.resource.data)
            || request.resource.data.dealerApplicationId is string
          )
          && (
            !("listingRestricted" in request.resource.data)
            || request.resource.data.listingRestricted is bool
          )
        );
      allow delete: if isSuperAdmin();
    }

    match /dealerApplications/{applicationId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
        );
      allow create, update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == applicationId
          && request.resource.data.keys().hasOnly([
            "userId",
            "dealerStatus",
            "legalBusinessName",
            "tradingName",
            "abn",
            "acn",
            "lmctNumber",
            "contactPersonName",
            "contactPhone",
            "contactEmail",
            "businessAddressLine1",
            "businessSuburb",
            "businessPostcode",
            "businessState",
            "licenceState",
            "licenceExpiry",
            "licenceVerificationStatus",
            "licenceVerificationNote",
            "licenceVerificationSource",
            "lmctProofUploadUrl",
            "lmctProofUploadName",
            "lmctProofUploadContentType",
            "riskLevel",
            "spamRiskLevel",
            "duplicateFlags",
            "duplicateMatchFlags",
            "duplicateMatchedApplicationIds",
            "trustIndicators",
            "rejectionHistoryCount",
            "status",
            "requestedAt",
            "lastSubmittedAt",
            "updatedAt",
            "reviewedAt",
            "reviewedByUid"
          ])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.dealerStatus == "pending"
          && request.resource.data.status == "pending"
          && request.resource.data.legalBusinessName is string
          && request.resource.data.tradingName is string
          && request.resource.data.abn is string
          && request.resource.data.acn is string
          && request.resource.data.lmctNumber is string
          && request.resource.data.contactPersonName is string
          && request.resource.data.contactPhone is string
          && request.resource.data.contactEmail is string
          && request.resource.data.businessAddressLine1 is string
          && request.resource.data.businessSuburb is string
          && request.resource.data.businessPostcode is string
          && request.resource.data.businessState is string
          && request.resource.data.licenceState is string
          && request.resource.data.licenceExpiry is string
          && (
            request.resource.data.licenceVerificationStatus == "verified"
            || request.resource.data.licenceVerificationStatus == "manual_review_required"
            || request.resource.data.licenceVerificationStatus == "auto_failed"
          )
          && (
            !("licenceVerificationNote" in request.resource.data)
            || request.resource.data.licenceVerificationNote is string
          )
          && (
            !("licenceVerificationSource" in request.resource.data)
            || request.resource.data.licenceVerificationSource is string
          )
          && request.resource.data.lmctProofUploadUrl is string
          && (
            request.resource.data.riskLevel == "low"
            || request.resource.data.riskLevel == "medium"
            || request.resource.data.riskLevel == "high"
          )
          && (
            request.resource.data.spamRiskLevel == "low"
            || request.resource.data.spamRiskLevel == "medium"
            || request.resource.data.spamRiskLevel == "high"
          )
          && request.resource.data.duplicateFlags is map
          && request.resource.data.duplicateMatchFlags is map
          && request.resource.data.duplicateMatchedApplicationIds is list
          && request.resource.data.trustIndicators is map
          && request.resource.data.rejectionHistoryCount is int
          && request.resource.data.lastSubmittedAt is timestamp
          && (
            !("lmctProofUploadName" in request.resource.data)
            || request.resource.data.lmctProofUploadName is string
          )
          && (
            !("lmctProofUploadContentType" in request.resource.data)
            || request.resource.data.lmctProofUploadContentType is string
          )
          && (
            !("reviewedAt" in request.resource.data)
            || request.resource.data.reviewedAt == null
          )
          && (
            !("reviewedByUid" in request.resource.data)
            || request.resource.data.reviewedByUid == null
          )
        );
      allow delete: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.ownerUid == request.auth.uid)
        || (
          (!("deleted" in resource.data) || resource.data.deleted == false)
          && (
            !("deletedAt" in resource.data)
            || resource.data.deletedAt == null
          )
          && resource.data.status == "approved"
          && (
            resource.data.sellerStatus == "ACTIVE"
            || resource.data.sellerStatus == "UNDER_OFFER"
            || resource.data.sellerStatus == "SOLD"
          )
        );
      allow create: if isAdmin()
        || (
          isSellerWorkspaceUser()
          && (userDoc().data.role != "dealer" || isApprovedDealer())
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerRole == "seller"
          && request.resource.data.status == "pending"
          && request.resource.data.sellerStatus == "ACTIVE"
        );
      allow update: if isAdmin()
        || (
          (isSeller() || isApprovedDealer())
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.ownerRole == resource.data.ownerRole
          && isValidVehicleStatus(request.resource.data.status)
          && isValidSellerVehicleStatus(request.resource.data.sellerStatus)
          && request.resource.data.status == resource.data.status
        )
        || (
          signedIn()
          && resource.data.underOfferBuyerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.ownerRole == resource.data.ownerRole
          && request.resource.data.status == resource.data.status
          && request.resource.data.sellerStatus == "ACTIVE"
          && (
            !("underOfferBuyerUid" in request.resource.data)
            || request.resource.data.underOfferBuyerUid == ""
          )
          && vehicleStatusFieldsOnlyChanged()
        );
      allow delete: if isAdmin();
    }

    match /vehicle_private/{vehicleId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.ownerUid == request.auth.uid
        );
      allow create, update: if isAdmin()
        || (
          (isSeller() || isApprovedDealer())
          && get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
        );
      allow delete: if isAdmin()
        || (
          (isSeller() || isApprovedDealer())
          && get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.ownerUid == request.auth.uid
        );
    }

    match /complianceAlerts/{userId} {
      allow read: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
        );
      allow create, update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly([
            "userId",
            "alertType",
            "status",
            "activityCount",
            "activities",
            "triggeredByVehicleId",
            "createdAt",
            "updatedAt",
            "resolvedAt"
          ])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.alertType == "possible_unlicensed_trader"
          && (
            request.resource.data.status == "open"
            || request.resource.data.status == "resolved"
          )
          && request.resource.data.activityCount is int
          && request.resource.data.activities is list
          && request.resource.data.updatedAt is timestamp
          && (
            !("createdAt" in request.resource.data)
            || request.resource.data.createdAt is timestamp
          )
          && (
            !("resolvedAt" in request.resource.data)
            || request.resource.data.resolvedAt is timestamp
          )
        );
      allow delete: if isAdmin();
    }

    match /enquiries/{id} {
      allow read, write: if false;
    }

    match /offers/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "buyerUid",
          "listingOwnerUid",
          "userId",
          "vehicleId",
          "vehicleTitle",
          "vehiclePrice",
          "buyerName",
          "buyerEmail",
          "buyerPhone",
          "amount",
          "offerAmount",
          "message",
          "messages",
          "buyerViewed",
          "sellerViewed",
          "contactUnlocked",
          "contactUnlockedAt",
          "contactUnlockedBy",
          "contactVisibilityState",
          "lastUpdatedBy",
          "sellerOwnerUid",
          "submittedByUid",
          "status",
          "createdAt",
          "updatedAt",
          "respondedAt"
        ])
        && request.resource.data.buyerUid == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.listingOwnerUid is string
        && request.resource.data.vehicleId is string
        && request.resource.data.vehicleTitle is string
        && request.resource.data.vehiclePrice is number
        && request.resource.data.buyerName is string
        && request.resource.data.buyerEmail is string
        && request.resource.data.buyerPhone is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.offerAmount is number
        && request.resource.data.offerAmount > 0
        && request.resource.data.message is string
        && request.resource.data.messages is list
        && request.resource.data.sellerOwnerUid is string
        && isValidOfferStatus(request.resource.data.status)
        && request.resource.data.status == "pending"
        && request.resource.data.buyerViewed == true
        && request.resource.data.sellerViewed == false
        && request.resource.data.contactUnlocked == false
        && request.resource.data.contactUnlockedAt == null
        && request.resource.data.contactUnlockedBy == null
        && request.resource.data.contactVisibilityState == "hidden"
        && request.resource.data.lastUpdatedBy == "buyer"
        && request.resource.data.submittedByUid == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.respondedAt == null
        && request.resource.data.listingOwnerUid == vehicleOwnerUid(request.resource.data.vehicleId)
        && request.resource.data.sellerOwnerUid == vehicleOwnerUid(request.resource.data.vehicleId)
        && (
          !("deleted" in get(/databases/$(database)/documents/vehicles/$(request.resource.data.vehicleId)).data)
          || get(/databases/$(database)/documents/vehicles/$(request.resource.data.vehicleId)).data.deleted == false
        )
        && get(/databases/$(database)/documents/vehicles/$(request.resource.data.vehicleId)).data.status == "approved"
        && get(/databases/$(database)/documents/vehicles/$(request.resource.data.vehicleId)).data.sellerStatus == "ACTIVE";
      allow read: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.sellerOwnerUid == request.auth.uid
            || resource.data.listingOwnerUid == request.auth.uid
            || resource.data.userId == request.auth.uid
            || resource.data.buyerUid == request.auth.uid
          )
        );
      allow update: if (
          isAdmin()
          && isValidOfferStatus(request.resource.data.status)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && offerContactUnlockFieldsValid()
          && request.resource.data.messages is list
          && request.resource.data.buyerViewed is bool
          && request.resource.data.sellerViewed is bool
          && request.resource.data.updatedAt is timestamp
          && (request.resource.data.respondedAt == null || request.resource.data.respondedAt is timestamp)
        )
        || (
          signedIn()
          && (resource.data.sellerOwnerUid == request.auth.uid || resource.data.listingOwnerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "sellerViewed",
            "updatedAt"
          ])
          && request.resource.data.messages == resource.data.messages
          && offerAmountsUnchanged()
          && offerContactUnlockFieldsUnchanged()
          && request.resource.data.lastUpdatedBy == resource.data.lastUpdatedBy
          && request.resource.data.buyerViewed == resource.data.buyerViewed
          && request.resource.data.sellerViewed == true
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt == resource.data.respondedAt
        )
        || (
          signedIn()
          && (resource.data.sellerOwnerUid == request.auth.uid || resource.data.listingOwnerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && resource.data.status == "pending"
          && (
            request.resource.data.status == "accepted"
            || request.resource.data.status == "declined"
          )
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "buyerViewed",
            "sellerViewed",
            "contactUnlocked",
            "contactUnlockedAt",
            "contactUnlockedBy",
            "contactVisibilityState",
            "lastUpdatedBy",
            "respondedAt",
            "updatedAt"
          ])
          && request.resource.data.messages == resource.data.messages
          && request.resource.data.amount == resource.data.amount
          && request.resource.data.offerAmount == resource.data.offerAmount
          && request.resource.data.lastUpdatedBy == "seller"
          && request.resource.data.buyerViewed == false
          && request.resource.data.sellerViewed == true
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt is timestamp
          && (
            (
              request.resource.data.status == "accepted"
              && request.resource.data.contactUnlocked == true
              && request.resource.data.contactUnlockedAt is timestamp
              && request.resource.data.contactUnlockedBy == "seller_accept"
              && request.resource.data.contactVisibilityState == "shared_after_accept"
            )
            || (
              request.resource.data.status == "declined"
              && request.resource.data.contactUnlocked == false
              && request.resource.data.contactUnlockedAt == null
              && request.resource.data.contactUnlockedBy == null
              && request.resource.data.contactVisibilityState == "hidden"
            )
          )
        )
        || (
          signedIn()
          && (resource.data.sellerOwnerUid == request.auth.uid || resource.data.listingOwnerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && isValidOfferStatus(request.resource.data.status)
          && resource.data.status == "pending"
          && (
            request.resource.data.status == "accepted_pending_buyer_confirmation"
            || request.resource.data.status == "rejected"
          )
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "buyerViewed",
            "sellerViewed",
            "respondedAt",
            "updatedAt"
          ])
          && request.resource.data.messages == resource.data.messages
          && request.resource.data.amount == resource.data.amount
          && request.resource.data.offerAmount == resource.data.offerAmount
          && offerContactUnlockFieldsUnchanged()
          && request.resource.data.lastUpdatedBy == resource.data.lastUpdatedBy
          && request.resource.data.buyerViewed == false
          && request.resource.data.sellerViewed == true
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt is timestamp
        )
        || (
          signedIn()
          && (resource.data.userId == request.auth.uid || resource.data.buyerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "buyerViewed",
            "updatedAt"
          ])
          && request.resource.data.messages == resource.data.messages
          && offerAmountsUnchanged()
          && offerContactUnlockFieldsUnchanged()
          && request.resource.data.lastUpdatedBy == resource.data.lastUpdatedBy
          && request.resource.data.buyerViewed == true
          && request.resource.data.sellerViewed == resource.data.sellerViewed
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt == resource.data.respondedAt
        )
        || (
          signedIn()
          && (resource.data.userId == request.auth.uid || resource.data.buyerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && resource.data.status == "countered"
          && (
            request.resource.data.status == "accepted"
            || request.resource.data.status == "declined"
          )
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "buyerViewed",
            "sellerViewed",
            "contactUnlocked",
            "contactUnlockedAt",
            "contactUnlockedBy",
            "contactVisibilityState",
            "lastUpdatedBy",
            "respondedAt",
            "updatedAt"
          ])
          && request.resource.data.messages == resource.data.messages
          && offerAmountsUnchanged()
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt is timestamp
          && (
            (
              request.resource.data.status == "accepted"
              && request.resource.data.lastUpdatedBy == "buyer"
              && request.resource.data.buyerViewed == true
              && request.resource.data.sellerViewed == false
              && request.resource.data.contactUnlocked == true
              && request.resource.data.contactUnlockedAt is timestamp
              && request.resource.data.contactUnlockedBy == "buyer_counter_accept"
              && request.resource.data.contactVisibilityState == "shared_after_counter_accept"
            )
            || (
              request.resource.data.status == "declined"
              && request.resource.data.lastUpdatedBy == "buyer"
              && request.resource.data.buyerViewed == true
              && request.resource.data.sellerViewed == true
              && request.resource.data.contactUnlocked == false
              && request.resource.data.contactUnlockedAt == null
              && request.resource.data.contactUnlockedBy == null
              && request.resource.data.contactVisibilityState == "hidden"
            )
          )
        )
        || (
          signedIn()
          && (resource.data.userId == request.auth.uid || resource.data.buyerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && resource.data.status == "accepted_pending_buyer_confirmation"
          && (
            request.resource.data.status == "buyer_confirmed"
            || request.resource.data.status == "buyer_declined"
          )
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status",
            "buyerViewed",
            "sellerViewed",
            "contactUnlocked",
            "contactUnlockedAt",
            "contactUnlockedBy",
            "contactVisibilityState",
            "lastUpdatedBy",
            "updatedAt"
          ])
          && request.resource.data.messages == resource.data.messages
          && offerAmountsUnchanged()
          && request.resource.data.buyerViewed == true
          && request.resource.data.sellerViewed == true
          && (
            (
              request.resource.data.status == "buyer_confirmed"
              && request.resource.data.lastUpdatedBy == "buyer"
              && request.resource.data.contactUnlocked == true
              && request.resource.data.contactUnlockedAt is timestamp
              && request.resource.data.contactUnlockedBy == "buyer_confirm"
              && request.resource.data.contactVisibilityState == "shared_after_accept"
            )
            || (
              request.resource.data.status == "buyer_declined"
              && request.resource.data.lastUpdatedBy == "buyer"
              && offerContactUnlockFieldsUnchanged()
            )
          )
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt == resource.data.respondedAt
        )
        || (
          signedIn()
          && (resource.data.userId == request.auth.uid || resource.data.buyerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && resource.data.status == "buyer_declined"
          && request.resource.data.status == "pending"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "amount",
            "offerAmount",
            "status",
            "messages",
            "buyerViewed",
            "sellerViewed",
            "lastUpdatedBy",
            "respondedAt",
            "updatedAt"
          ])
          && request.resource.data.lastUpdatedBy == "buyer"
          && offerContactUnlockFieldsUnchanged()
          && request.resource.data.buyerViewed == true
          && request.resource.data.sellerViewed == false
          && request.resource.data.respondedAt == null
          && request.resource.data.updatedAt is timestamp
        )
        || (
          signedIn()
          && (resource.data.sellerOwnerUid == request.auth.uid || resource.data.listingOwnerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && isValidOfferStatus(request.resource.data.status)
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "contactUnlocked",
            "contactUnlockedAt",
            "contactUnlockedBy",
            "contactVisibilityState",
            "buyerViewed",
            "sellerViewed",
            "updatedAt"
          ])
          && request.resource.data.messages == resource.data.messages
          && offerAmountsUnchanged()
          && resource.data.contactUnlocked == false
          && request.resource.data.contactUnlocked == true
          && request.resource.data.contactUnlockedAt is timestamp
          && request.resource.data.contactUnlockedBy == "seller_manual"
          && request.resource.data.contactVisibilityState == "shared_after_accept"
          && request.resource.data.lastUpdatedBy == resource.data.lastUpdatedBy
          && request.resource.data.buyerViewed == false
          && request.resource.data.sellerViewed == true
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt == resource.data.respondedAt
        )
        || (
          signedIn()
          && (resource.data.sellerOwnerUid == request.auth.uid || resource.data.listingOwnerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && resource.data.status == "pending"
          && request.resource.data.status == "pending"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "messages",
            "buyerViewed",
            "sellerViewed",
            "updatedAt"
          ])
          && offerAmountsUnchanged()
          && offerContactUnlockFieldsUnchanged()
          && request.resource.data.lastUpdatedBy == resource.data.lastUpdatedBy
          && request.resource.data.buyerViewed == false
          && request.resource.data.sellerViewed == true
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt == resource.data.respondedAt
        )
        || (
          signedIn()
          && (resource.data.userId == request.auth.uid || resource.data.buyerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && resource.data.status == "pending"
          && request.resource.data.status == "pending"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "messages",
            "buyerViewed",
            "sellerViewed",
            "updatedAt"
          ])
          && offerAmountsUnchanged()
          && offerContactUnlockFieldsUnchanged()
          && request.resource.data.lastUpdatedBy == resource.data.lastUpdatedBy
          && request.resource.data.buyerViewed == true
          && request.resource.data.sellerViewed == false
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt == resource.data.respondedAt
        )
        || (
          signedIn()
          && (resource.data.sellerOwnerUid == request.auth.uid || resource.data.listingOwnerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && resource.data.status == "pending"
          && request.resource.data.status == "countered"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "amount",
            "offerAmount",
            "status",
            "messages",
            "buyerViewed",
            "sellerViewed",
            "lastUpdatedBy",
            "respondedAt",
            "updatedAt"
          ])
          && request.resource.data.lastUpdatedBy == "seller"
          && offerContactUnlockFieldsUnchanged()
          && request.resource.data.buyerViewed == false
          && request.resource.data.sellerViewed == true
          && request.resource.data.respondedAt is timestamp
          && request.resource.data.updatedAt is timestamp
        )
        || (
          signedIn()
          && (resource.data.userId == request.auth.uid || resource.data.buyerUid == request.auth.uid)
          && offerFieldsUnchanged()
          && offerAmountsAreValid()
          && request.resource.data.messages is list
          && (resource.data.status == "pending" || resource.data.status == "countered")
          && request.resource.data.status == "pending"
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "amount",
            "offerAmount",
            "messages",
            "buyerViewed",
            "sellerViewed",
            "lastUpdatedBy",
            "updatedAt"
          ])
          && request.resource.data.lastUpdatedBy == "buyer"
          && offerContactUnlockFieldsUnchanged()
          && request.resource.data.buyerViewed == true
          && request.resource.data.sellerViewed == false
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.respondedAt == null
        );
      allow delete: if isAdmin();
    }

    match /inspectionRequests/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "vehicleId",
          "vehicleTitle",
          "buyerName",
          "buyerEmail",
          "buyerPhone",
          "preferredTime",
          "message",
          "status",
          "createdAt",
          "listingType",
          "sellerOwnerUid",
          "submittedByUid"
        ])
        && request.resource.data.vehicleId is string
        && request.resource.data.vehicleTitle is string
        && request.resource.data.buyerName is string
        && request.resource.data.buyerEmail is string
        && request.resource.data.buyerPhone is string
        && request.resource.data.preferredTime is string
        && request.resource.data.message is string
        && request.resource.data.listingType is string
        && request.resource.data.sellerOwnerUid is string
        && isValidInspectionRequestStatus(request.resource.data.status)
        && request.resource.data.status == "NEW"
        && request.resource.data.submittedByUid == request.auth.uid
        && request.resource.data.createdAt is timestamp;
      allow read: if isAdmin()
        || (isSeller() && resource.data.sellerOwnerUid == request.auth.uid)
        || (signedIn() && resource.data.submittedByUid == request.auth.uid);
      allow update: if (
          isAdmin()
          || (isSeller() && resource.data.sellerOwnerUid == request.auth.uid)
        )
        && isValidInspectionRequestStatus(request.resource.data.status)
        && inspectionRequestFieldsUnchanged();
      allow delete: if isAdmin();
    }

    match /quotes/{id} {
      allow create: if isSeller()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.sellerUid == request.auth.uid
        && request.resource.data.sellerName is string
        && request.resource.data.sellerEmail is string
        && request.resource.data.vehicleYear is number
        && request.resource.data.vehicleMake is string
        && request.resource.data.vehicleModel is string
        && request.resource.data.quoteType is string
        && request.resource.data.source is string
        && request.resource.data.notes is string
        && isValidQuoteStatus(request.resource.data.status)
        && request.resource.data.status == "NEW";
      allow read: if isAdmin()
        || (isSeller() && resource.data.ownerId == request.auth.uid);
      allow update: if isAdmin()
        && isValidQuoteStatus(request.resource.data.status)
        && quoteFieldsUnchanged();
      allow delete: if isAdmin();
    }

    match /contact_messages/{id} {
      allow create: if request.resource.data.keys().hasOnly([
          "name",
          "email",
          "phone",
          "subject",
          "message",
          "category",
          "status",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.subject is string
        && request.resource.data.message is string
        && request.resource.data.category is string
        && isValidContactMessageStatus(request.resource.data.status)
        && request.resource.data.status == "NEW"
        && request.resource.data.createdAt is timestamp;
      allow read: if isAdmin();
      allow update: if isAdmin()
        && isValidContactMessageStatus(request.resource.data.status)
        && request.resource.data.name == resource.data.name
        && request.resource.data.email == resource.data.email
        && request.resource.data.phone == resource.data.phone
        && request.resource.data.subject == resource.data.subject
        && request.resource.data.message == resource.data.message
        && request.resource.data.category == resource.data.category
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /pricingRequests/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "userId",
          "vehicleId",
          "currentPrice",
          "timeline",
          "message",
          "status",
          "leadRating",
          "nextAction",
          "createdAt",
          "response",
          "respondedAt"
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.timeline is string
        && request.resource.data.message is string
        && isValidPricingRequestStatus(request.resource.data.status)
        && request.resource.data.status == "NEW"
        && request.resource.data.response is string
        && (
          !("vehicleId" in request.resource.data)
          || request.resource.data.vehicleId is string
        )
        && (
          !("currentPrice" in request.resource.data)
          || request.resource.data.currentPrice is number
        )
        && request.resource.data.createdAt is timestamp;
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          "userId",
          "vehicleId",
          "currentPrice",
          "timeline",
          "message",
          "status",
          "leadRating",
          "nextAction",
          "createdAt",
          "response",
          "respondedAt"
        ])
        && pricingRequestBaseFieldsUnchanged()
        && isValidPricingRequestStatus(request.resource.data.status)
        && request.resource.data.response is string
        && (
          !("leadRating" in request.resource.data)
          || isValidPricingLeadRating(request.resource.data.leadRating)
        )
        && (
          !("nextAction" in request.resource.data)
          || isValidPricingNextAction(request.resource.data.nextAction)
        );
      allow delete: if isAdmin();
    }

    match /savedVehicles/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "userId",
          "vehicleId",
          "createdAt"
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.vehicleId is string
        && request.resource.data.createdAt is timestamp;
      allow read, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.vehicleId == resource.data.vehicleId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "lastViewedActivityAt"
        ])
        && request.resource.data.lastViewedActivityAt is timestamp;
    }

    match /offerActivityNotifications/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "vehicleId",
          "offerId",
          "relatedOfferId",
          "recipientUserId",
          "recipientEmail",
          "actorUid",
          "subject",
          "message",
          "vehicleLink",
          "deliveryChannel",
          "createdAt"
        ])
        && request.resource.data.vehicleId is string
        && request.resource.data.offerId is string
        && request.resource.data.relatedOfferId is string
        && request.resource.data.recipientUserId is string
        && request.resource.data.recipientEmail is string
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.subject == "Update on your offer activity"
        && request.resource.data.message is string
        && request.resource.data.vehicleLink is string
        && request.resource.data.deliveryChannel == "email"
        && request.resource.data.createdAt is timestamp
        && request.resource.data.recipientUserId != request.auth.uid
        && offerActivityNotificationOffer(request.resource.data.offerId).data.buyerUid == request.auth.uid
        && offerActivityNotificationOffer(request.resource.data.offerId).data.vehicleId == request.resource.data.vehicleId
        && offerActivityNotificationOffer(request.resource.data.relatedOfferId).data.vehicleId == request.resource.data.vehicleId
        && offerActivityNotificationOffer(request.resource.data.relatedOfferId).data.buyerUid == request.resource.data.recipientUserId;
      allow read: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.recipientUserId == request.auth.uid
            || resource.data.actorUid == request.auth.uid
          )
        );
      allow update, delete: if false;
    }

    match /mail/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "to",
          "message",
          "offerActivityNotificationId",
          "type",
          "createdAt"
        ])
        && request.resource.data.to is string
        && request.resource.data.message is map
        && request.resource.data.offerActivityNotificationId is string
        && request.resource.data.type == "offer_activity"
        && request.resource.data.createdAt is timestamp
        && get(/databases/$(database)/documents/offerActivityNotifications/$(request.resource.data.offerActivityNotificationId)).data.actorUid == request.auth.uid
        && get(/databases/$(database)/documents/offerActivityNotifications/$(request.resource.data.offerActivityNotificationId)).data.recipientEmail == request.resource.data.to;
      allow read, update, delete: if false;
    }

    match /vehicleActivityEvents/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          "vehicleId",
          "type",
          "message",
          "actorUid",
          "createdAt"
        ])
        && request.resource.data.vehicleId is string
        && request.resource.data.type == "offer_created"
        && request.resource.data.message is string
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.createdAt is timestamp;
      allow read: if signedIn();
      allow update, delete: if false;
    }

    match /vehicleViewEvents/{id} {
      allow create: if request.resource.data.vehicleId is string
        && request.resource.data.sessionId is string
        && isValidVehicleViewRole(request.resource.data.role)
        && request.resource.data.source is string
        && request.resource.data.referrer is string
        && isValidDeviceType(request.resource.data.deviceType)
        && request.resource.data.listingType is string
        && request.resource.data.sellerOwnerUid is string
        && (!("userId" in request.resource.data) || (signedIn() && request.resource.data.userId == request.auth.uid))
        && (
          (!signedIn() && request.resource.data.role == "guest" && !("userId" in request.resource.data))
          || (signedIn() && request.resource.data.role == userDoc().data.role)
        )
        && request.resource.data.viewedAt is timestamp;
      allow read: if isAdmin()
        || (isSeller() && resource.data.sellerOwnerUid == request.auth.uid);
      allow update, delete: if false;
    }

    match /vehicleAnalytics/{vehicleId} {
      allow read: if isAdmin()
        || (isSeller() && resource.data.sellerOwnerUid == request.auth.uid);
      allow create, update: if isAdmin()
        || (isSeller() && request.resource.data.sellerOwnerUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /viewing_requests/{id} {
      allow read, write: if signedIn();
    }

    match /change_requests/{id} {
      allow read, write: if signedIn();
    }
  }
}
